{
  "name": "dota2-tracker",
  "version": "1.0.0",
  "description": "Live Dota 2 stats tracker using Valve's Game State Integration (GSI)",
  "main": "server.js",
  "bin": "launcher.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "launcher": "node launcher.js",
    "dev": "node --watch server.js",
    "install-cfg": "node scripts/install-gsi-config.js",
    "mock": "node scripts/mock-gsi.js",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/Dota2Tracker.exe",
    "build:all": "pkg . --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --out-path dist"
  },
  "keywords": [
    "dota2",
    "gsi",
    "game-state-integration",
    "tracker",
    "stats"
  ],
  "author": "ReXaXeR",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.2"
  },
  "pkg": {
    "scripts": [
      "server.js",
      "lib/**/*.js"
    ],
    "assets": [
      "public/**/*",
      "gamestate_integration_tracker.cfg"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  }
}
